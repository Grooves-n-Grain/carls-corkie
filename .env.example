# ─── Authentication ──────────────────────────────────────
# Auto-generated on first `npm run dev`, `npm run build`, or `npm run pm2:start`.
# Rotate:  npm run token:rotate     (then restart server + rebuild client)
# Show:    npm run token:show
# Disable: CORKBOARD_AUTH=disabled   (only if you terminate auth at a reverse proxy)
CORKBOARD_TOKEN=
VITE_CORKBOARD_TOKEN=
# CORKBOARD_AUTH=disabled

# ─── Server ───────────────────────────────────────────────
PORT=3010
CORKBOARD_HOST=0.0.0.0

# Comma-separated list of allowed CORS origins.
# For Vite dev access from another device, add http://<your-lan-ip>:5180.
CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180

# ─── Lamp / Home Assistant (optional) ─────────────────────
# Option A: Control a light via Home Assistant
# HA_URL=http://192.168.1.100:8123
# HA_TOKEN=your-long-lived-access-token
# HA_LIGHT_ENTITY=light.my_light
#
# Option B: External lamp server (advanced)
# Used when Home Assistant is not available but you still want lamp state updates.
# LAMP_SERVER=http://192.168.1.100:3011

# ─── Client (Vite) ───────────────────────────────────────
# Leave empty for same-origin (works with Vite proxy in dev, Express static in prod)
VITE_API_URL=
VITE_SOCKET_URL=
